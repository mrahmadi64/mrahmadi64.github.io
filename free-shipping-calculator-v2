<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>ماشین حساب حمل رایگان</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Vazirmatn:wght@300;400;500;600;700&display=swap');

  :root {
    --bg: #F5F6F8;
    --card: #FFFFFF;
    --border: #E2E5EA;
    --text: #1A1D23;
    --muted: #6B7280;
    --primary: #1C4ED8;
    --primary-light: #EFF6FF;
    --success: #16A34A;
    --success-light: #F0FDF4;
    --warning: #D97706;
    --warning-light: #FFFBEB;
    --danger: #DC2626;
    --danger-light: #FEF2F2;
    --radius: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Vazirmatn', sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    line-height: 1.6;
    min-height: 100vh;
  }

  /* ── Header ── */
  .app-header {
    background: var(--card);
    border-bottom: 1px solid var(--border);
    padding: 14px 24px;
    display: flex;
    align-items: center;
    gap: 12px;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .app-header .logo {
    width: 32px; height: 32px;
    background: var(--primary);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 18px;
  }
  .app-header h1 { font-size: 15px; font-weight: 600; }
  .app-header p { font-size: 12px; color: var(--muted); }

  /* ── Batch Status Badge ── */
  .batch-status {
    margin: 20px 24px 0;
    border-radius: var(--radius);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 14px;
    font-weight: 500;
    transition: all .3s;
  }
  .batch-status.waiting  { background: #F8FAFC; border: 1.5px dashed var(--border); color: var(--muted); }
  .batch-status.blocked  { background: var(--warning-light); border: 1.5px solid #FDE68A; color: var(--warning); }
  .batch-status.approved { background: var(--success-light); border: 1.5px solid #BBF7D0; color: var(--success); }
  .batch-status .status-icon { font-size: 28px; line-height: 1; }
  .batch-status .status-label { font-size: 12px; font-weight: 400; opacity: .8; }
  .batch-status .status-title { font-size: 16px; font-weight: 700; }

  /* ── Fill Bar ── */
  .fill-bar-wrap {
    margin: 8px 24px 0;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 20px;
  }
  .fill-bar-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 8px;
  }
  .fill-bar-header span { font-size: 12px; color: var(--muted); }
  .fill-bar-header strong { font-size: 14px; color: var(--text); }
  .fill-bar-track {
    height: 10px;
    background: #E5E7EB;
    border-radius: 999px;
    overflow: hidden;
  }
  .fill-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width .5s ease, background .3s;
    background: var(--primary);
  }
  .fill-bar-fill.good  { background: var(--success); }
  .fill-bar-fill.warn  { background: var(--warning); }
  .fill-bar-fill.low   { background: var(--danger); }

  /* ── Main layout ── */
  .main {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 16px;
    padding: 16px 24px 32px;
    max-width: 1280px;
    margin: 0 auto;
  }
  @media (max-width: 900px) {
    .main { grid-template-columns: 1fr; }
  }

  /* ── Card ── */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .card-header {
    padding: 14px 18px;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
    font-size: 13px;
    display: flex; align-items: center; gap: 8px;
  }
  .card-header .step {
    width: 22px; height: 22px;
    background: var(--primary);
    color: #fff;
    border-radius: 50%;
    font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; flex-shrink: 0;
  }

  /* ── Form ── */
  .form-body { padding: 16px 18px; display: flex; flex-direction: column; gap: 12px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .form-group { display: flex; flex-direction: column; gap: 4px; }
  .form-group.full { grid-column: 1/-1; }
  label { font-size: 12px; color: var(--muted); font-weight: 500; }
  input, select {
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 8px 10px;
    font-family: inherit;
    font-size: 13px;
    color: var(--text);
    background: var(--bg);
    transition: border .2s;
    width: 100%;
  }
  input:focus, select:focus {
    outline: none;
    border-color: var(--primary);
    background: #fff;
  }
  .hint { font-size: 11px; color: var(--muted); margin-top: 2px; }

  /* ── Stats grid ── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border-radius: 0 0 var(--radius) var(--radius);
    overflow: hidden;
  }
  .stat-cell {
    background: var(--card);
    padding: 12px 16px;
  }
  .stat-cell.highlight {
    background: var(--primary-light);
  }
  .stat-cell.success-bg { background: var(--success-light); }
  .stat-cell .s-label { font-size: 11px; color: var(--muted); margin-bottom: 2px; }
  .stat-cell .s-value { font-size: 15px; font-weight: 700; color: var(--text); }
  .stat-cell.highlight .s-value { color: var(--primary); }
  .stat-cell.success-bg .s-value { color: var(--success); }
  .stat-cell.span2 { grid-column: 1/-1; }

  /* ── Customers table ── */
  .customers-section { display: flex; flex-direction: column; }
  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  thead th {
    background: #F8FAFC;
    padding: 10px 12px;
    text-align: right;
    font-size: 11px;
    color: var(--muted);
    font-weight: 600;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  tbody tr { border-bottom: 1px solid var(--border); transition: background .15s; }
  tbody tr:hover { background: #FAFBFC; }
  tbody tr:last-child { border-bottom: none; }
  td { padding: 9px 12px; vertical-align: middle; }
  td input {
    border: 1px solid transparent;
    background: transparent;
    padding: 4px 6px;
    width: 100%;
    min-width: 80px;
    border-radius: 5px;
    font-size: 13px;
  }
  td input:hover { border-color: var(--border); background: var(--bg); }
  td input:focus { border-color: var(--primary); background: #fff; }

  /* Status pill */
  .pill {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 8px; border-radius: 999px;
    font-size: 11px; font-weight: 600; white-space: nowrap;
  }
  .pill.free    { background: var(--success-light); color: var(--success); }
  .pill.partial { background: var(--warning-light); color: var(--warning); }
  .pill.paid    { background: var(--danger-light);  color: var(--danger); }
  .pill.–       { background: #F1F5F9; color: var(--muted); }

  /* ── Buttons ── */
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: 7px;
    border: none; cursor: pointer;
    font-family: inherit; font-size: 13px; font-weight: 500;
    transition: opacity .15s, background .15s;
  }
  .btn:hover { opacity: .85; }
  .btn-primary { background: var(--primary); color: #fff; }
  .btn-ghost   { background: var(--bg); color: var(--text); border: 1px solid var(--border); }
  .btn-danger  { background: var(--danger-light); color: var(--danger); border: none; padding: 4px 8px; }
  .btn-sm { padding: 5px 10px; font-size: 12px; }

  .table-actions {
    padding: 12px 16px;
    display: flex; gap: 8px; flex-wrap: wrap;
    border-top: 1px solid var(--border);
    background: #FAFBFC;
    border-radius: 0 0 var(--radius) var(--radius);
  }

  /* ── Copy message box ── */
  .msg-box {
    margin: 0 24px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .msg-box-header {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border);
    font-size: 13px; font-weight: 600;
    display: flex; justify-content: space-between; align-items: center;
  }
  .msg-box-body {
    padding: 14px 16px;
    font-size: 12.5px;
    line-height: 2;
    color: var(--text);
    white-space: pre-wrap;
    min-height: 80px;
    background: #FAFBFC;
  }

  /* ── Empty state ── */
  .empty-row td { text-align: center; color: var(--muted); padding: 24px; font-size: 12px; }

  /* ── Divider label ── */
  .section-gap { height: 4px; }
</style>
</head>
<body>

<!-- Header -->
<div class="app-header">
  <div class="logo">🚚</div>
  <div>
    <h1>ماشین حساب حمل رایگان</h1>
    <p>پروموشن کرایه مسیرمحور — مخصوص کارشناس فروش و لجستیک</p>
  </div>
</div>

<!-- Batch Status -->
<div class="batch-status waiting" id="batchStatus">
  <div class="status-icon">⏳</div>
  <div>
    <div class="status-label">وضعیت بچ</div>
    <div class="status-title" id="statusTitle">در انتظار ورود اطلاعات</div>
  </div>
</div>

<!-- Fill Progress Bar -->
<div class="fill-bar-wrap">
  <div class="fill-bar-header">
    <span>پرشدگی خودرو</span>
    <strong id="fillPct">—</strong>
  </div>
  <div class="fill-bar-track">
    <div class="fill-bar-fill low" id="fillBar" style="width:0%"></div>
  </div>
</div>

<div class="section-gap"></div>

<!-- Main grid -->
<div class="main">

  <!-- Left: Config + Stats -->
  <div style="display:flex;flex-direction:column;gap:16px;">

    <!-- Config card -->
    <div class="card">
      <div class="card-header"><span class="step">۱</span> مسیر، ماشین و سیاست</div>
      <div class="form-body">
        <div class="form-group">
          <label>مقصد / مسیر</label>
          <input type="text" id="route" placeholder="مثال: تهران — کرج">
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>نوع ماشین</label>
            <select id="truckType">
              <option value="">انتخاب کنید</option>
              <option value="van">ون</option>
              <option value="pickup">وانت</option>
              <option value="truck6">کامیونت ۶ تن</option>
              <option value="truck10">کامیون ۱۰ تن</option>
            </select>
          </div>
          <div class="form-group">
            <label>کد بچ ارسال</label>
            <input type="text" id="batchCode" placeholder="مثال: B-1042">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>نرخ حمل پایه (تومان)</label>
            <input type="number" id="baseRate" placeholder="۲۰۰۰۰۰۰" value="2000000">
          </div>
          <div class="form-group">
            <label>هزینه هر توقف اضافه (تومان)</label>
            <input type="number" id="stopCost" placeholder="۱۰۰۰۰۰" value="100000">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>ظرفیت ماشین (م‌م)</label>
            <input type="number" id="capacity" placeholder="۲۰" value="20">
          </div>
          <div class="form-group">
            <label>تعهد شرکت (٪ خرید)</label>
            <input type="number" id="commitPct" placeholder="۲" value="2" step="0.1" min="0" max="100">
          </div>
        </div>
        <div class="form-group">
          <label>حداقل پرشدگی خودرو (٪)</label>
          <input type="number" id="minFill" placeholder="۷۰" value="70" min="0" max="100">
          <span class="hint">صفر بگذارید تا این شرط حذف شود</span>
        </div>
      </div>
    </div>

    <!-- Stats card -->
    <div class="card">
      <div class="card-header"><span class="step">۳</span> خلاصه مسیر</div>
      <div class="stats-grid">
        <div class="stat-cell">
          <div class="s-label">تعداد مشتریان</div>
          <div class="s-value" id="sCount">—</div>
        </div>
        <div class="stat-cell">
          <div class="s-label">مجموع متراژ بار</div>
          <div class="s-value" id="sTotalM2">—</div>
        </div>
        <div class="stat-cell highlight span2">
          <div class="s-label">مجموع خرید مسیر</div>
          <div class="s-value" id="sTotalBuy">—</div>
        </div>
        <div class="stat-cell">
          <div class="s-label">کرایه پایه</div>
          <div class="s-value" id="sBaseFreight">—</div>
        </div>
        <div class="stat-cell">
          <div class="s-label">هزینه توقف‌های اضافه</div>
          <div class="s-value" id="sStopFee">—</div>
        </div>
        <div class="stat-cell highlight">
          <div class="s-label">کرایه کل مسیر</div>
          <div class="s-value" id="sTotalFreight">—</div>
        </div>
        <div class="stat-cell">
          <div class="s-label">سقف تعهد شرکت</div>
          <div class="s-value" id="sCompanyCap">—</div>
        </div>
        <div class="stat-cell success-bg">
          <div class="s-label">حداقل خرید برای حمل رایگان</div>
          <div class="s-value" id="sMinBuy">—</div>
        </div>
        <div class="stat-cell span2">
          <div class="s-label">کسری خرید تا حمل رایگان</div>
          <div class="s-value" id="sShortfall">—</div>
        </div>
      </div>
    </div>

  </div>

  <!-- Right: Customers + Allocation -->
  <div style="display:flex;flex-direction:column;gap:16px;">

    <!-- Customers -->
    <div class="card customers-section">
      <div class="card-header"><span class="step">۲</span> سفارش‌های مشتریان این مسیر</div>
      <div class="table-wrap">
        <table id="customersTable">
          <thead>
            <tr>
              <th>#</th>
              <th>نام مشتری</th>
              <th>مبلغ خرید (تومان)</th>
              <th>متراژ بار (م‌م)</th>
              <th>حذف</th>
            </tr>
          </thead>
          <tbody id="customersBody">
            <tr class="empty-row"><td colspan="5">هنوز مشتری اضافه نشده</td></tr>
          </tbody>
        </table>
      </div>
      <div class="table-actions">
        <button class="btn btn-primary btn-sm" onclick="addCustomer()">＋ افزودن مشتری</button>
        <button class="btn btn-ghost btn-sm" onclick="loadSample()">بارگذاری نمونه</button>
        <button class="btn btn-ghost btn-sm" onclick="exportCSV()">خروجی CSV</button>
      </div>
    </div>

    <!-- Allocation -->
    <div class="card">
      <div class="card-header"><span class="step">۴</span> تخصیص کرایه به مشتریان</div>
      <div class="table-wrap">
        <table id="allocTable">
          <thead>
            <tr>
              <th>مشتری</th>
              <th>خرید</th>
              <th>سهم کرایه</th>
              <th>سقف تعهد شرکت</th>
              <th>سهم شرکت</th>
              <th>سهم مشتری</th>
              <th>وضعیت</th>
            </tr>
          </thead>
          <tbody id="allocBody">
            <tr class="empty-row"><td colspan="7">پس از ورود اطلاعات محاسبه می‌شود</td></tr>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<!-- Message box -->
<div class="msg-box">
  <div class="msg-box-header">
    <span>📋 متن آماده برای ارسال به مشتری / ثبت در سیستم</span>
    <button class="btn btn-ghost btn-sm" onclick="copyMsg()">کپی متن</button>
  </div>
  <div class="msg-box-body" id="msgBox">پس از ورود اطلاعات مسیر و مشتریان، متن خودکار تولید می‌شود.</div>
</div>
<div style="height:40px;"></div>

<script>
  let customers = [];
  let cid = 0;

  function fmt(n) {
    if (n === null || n === undefined || isNaN(n)) return '—';
    return Math.round(n).toLocaleString('fa-IR');
  }
  function pct(n) {
    if (n === null || isNaN(n)) return '—';
    return (n).toFixed(1).replace(/\./g, '٫') + '٪';
  }

  function getConfig() {
    return {
      route: document.getElementById('route').value.trim(),
      batchCode: document.getElementById('batchCode').value.trim(),
      baseRate: parseFloat(document.getElementById('baseRate').value) || 0,
      stopCost: parseFloat(document.getElementById('stopCost').value) || 0,
      capacity: parseFloat(document.getElementById('capacity').value) || 0,
      commitPct: parseFloat(document.getElementById('commitPct').value) || 0,
      minFill: parseFloat(document.getElementById('minFill').value) || 0,
    };
  }

  function addCustomer(name='', buy='', m2='') {
    cid++;
    customers.push({ id: cid, name, buy, m2 });
    renderCustomers();
    recalc();
  }

  function removeCustomer(id) {
    customers = customers.filter(c => c.id !== id);
    renderCustomers();
    recalc();
  }

  function renderCustomers() {
    const tbody = document.getElementById('customersBody');
    if (customers.length === 0) {
      tbody.innerHTML = '<tr class="empty-row"><td colspan="5">هنوز مشتری اضافه نشده</td></tr>';
      return;
    }
    tbody.innerHTML = customers.map((c, i) => `
      <tr>
        <td style="color:var(--muted);font-size:12px;">${(i+1).toLocaleString('fa-IR')}</td>
        <td><input type="text" value="${c.name}" placeholder="نام مشتری" oninput="updateCustomer(${c.id},'name',this.value)"></td>
        <td><input type="number" value="${c.buy}" placeholder="مبلغ خرید" oninput="updateCustomer(${c.id},'buy',this.value)"></td>
        <td><input type="number" value="${c.m2}" placeholder="متراژ" oninput="updateCustomer(${c.id},'m2',this.value)"></td>
        <td><button class="btn btn-danger btn-sm" onclick="removeCustomer(${c.id})">✕</button></td>
      </tr>
    `).join('');
  }

  function updateCustomer(id, field, val) {
    const c = customers.find(x => x.id === id);
    if (c) { c[field] = val; recalc(); }
  }

  function recalc() {
    const cfg = getConfig();
    const validC = customers.filter(c => parseFloat(c.buy) > 0);

    const totalBuy = validC.reduce((s, c) => s + (parseFloat(c.buy)||0), 0);
    const totalM2  = validC.reduce((s, c) => s + (parseFloat(c.m2)||0), 0);
    const n = validC.length;

    // freight
    const extraStops  = Math.max(0, n - 1);
    const stopFee     = extraStops * cfg.stopCost;
    const totalFreight= cfg.baseRate + stopFee;

    // fill
    const fillPct = cfg.capacity > 0 ? (totalM2 / cfg.capacity) * 100 : 0;

    // company cap
    const companyCap = totalBuy * cfg.commitPct / 100;

    // free shipping: company pays all if companyCap >= totalFreight AND fill ok
    const fillOK = cfg.minFill === 0 || fillPct >= cfg.minFill;
    const freeShipping = totalBuy > 0 && companyCap >= totalFreight && fillOK;

    // min buy for free shipping
    const minBuy = cfg.commitPct > 0 ? (totalFreight / (cfg.commitPct / 100)) : null;
    const shortfall = minBuy !== null ? Math.max(0, minBuy - totalBuy) : null;

    // Update stats
    set('sCount',       n > 0 ? n.toLocaleString('fa-IR') : '—');
    set('sTotalM2',     n > 0 ? fmt(totalM2) + ' م‌م' : '—');
    set('sTotalBuy',    n > 0 ? fmt(totalBuy) + ' تومان' : '—');
    set('sBaseFreight', fmt(cfg.baseRate) + ' تومان');
    set('sStopFee',     fmt(stopFee) + ' تومان');
    set('sTotalFreight',fmt(totalFreight) + ' تومان');
    set('sCompanyCap',  n > 0 ? fmt(companyCap) + ' تومان' : '—');
    set('sMinBuy',      minBuy !== null ? fmt(minBuy) + ' تومان' : '—');
    set('sShortfall',   (n > 0 && shortfall !== null) ? (shortfall > 0 ? fmt(shortfall) + ' تومان' : '✅ شرط محقق شده') : '—');

    // Fill bar
    const bar = document.getElementById('fillBar');
    const fillDisp = cfg.capacity > 0 ? Math.min(fillPct, 100) : 0;
    bar.style.width = fillDisp + '%';
    bar.className = 'fill-bar-fill ' + (fillPct >= (cfg.minFill||70) ? 'good' : fillPct >= 50 ? 'warn' : 'low');
    set('fillPct', cfg.capacity > 0 ? pct(fillPct) : '—');

    // Batch status
    const statusEl = document.getElementById('batchStatus');
    const titleEl  = document.getElementById('statusTitle');
    if (n === 0) {
      statusEl.className = 'batch-status waiting';
      titleEl.textContent = 'در انتظار ورود اطلاعات';
    } else if (freeShipping) {
      statusEl.className = 'batch-status approved';
      titleEl.textContent = '✅ حمل رایگان مجاز — شرکت کل کرایه را پرداخت می‌کند';
    } else {
      let reason = [];
      if (companyCap < totalFreight) reason.push('خرید کافی نیست');
      if (!fillOK) reason.push('پرشدگی خودرو کم است');
      statusEl.className = 'batch-status blocked';
      titleEl.textContent = '⚠️ حمل رایگان فعال نیست — ' + reason.join(' | ');
    }

    // Allocation table
    const allocBody = document.getElementById('allocBody');
    if (n === 0) {
      allocBody.innerHTML = '<tr class="empty-row"><td colspan="7">پس از ورود اطلاعات محاسبه می‌شود</td></tr>';
      buildMsg(cfg, validC, totalBuy, totalFreight, freeShipping, fillPct, companyCap, minBuy, shortfall);
      return;
    }

    allocBody.innerHTML = validC.map(c => {
      const buy = parseFloat(c.buy)||0;
      const buyShare = totalBuy > 0 ? (buy / totalBuy) : 0;
      const freightShare = totalFreight * buyShare;
      const customerCap = buy * cfg.commitPct / 100;

      let companySh, customerSh, status, pill;
      if (freeShipping) {
        companySh  = freightShare;
        customerSh = 0;
        pill = '<span class="pill free">✅ حمل رایگان</span>';
      } else {
        companySh  = Math.min(freightShare, customerCap);
        customerSh = freightShare - companySh;
        if (customerSh <= 0) {
          customerSh = 0;
          pill = '<span class="pill partial">🟡 مشارکتی</span>';
        } else {
          pill = '<span class="pill paid">💰 پرداختی</span>';
        }
      }

      return `<tr>
        <td><strong>${c.name||'—'}</strong></td>
        <td>${fmt(buy)}</td>
        <td>${fmt(freightShare)}</td>
        <td>${fmt(customerCap)}</td>
        <td>${fmt(companySh)}</td>
        <td><strong>${fmt(customerSh)}</strong></td>
        <td>${pill}</td>
      </tr>`;
    }).join('');

    buildMsg(cfg, validC, totalBuy, totalFreight, freeShipping, fillPct, companyCap, minBuy, shortfall);
  }

  function buildMsg(cfg, customers, totalBuy, totalFreight, free, fillPct, cap, minBuy, shortfall) {
    const box = document.getElementById('msgBox');
    if (customers.length === 0) {
      box.textContent = 'پس از ورود اطلاعات مسیر و مشتریان، متن خودکار تولید می‌شود.';
      return;
    }
    const d = new Date().toLocaleDateString('fa-IR');
    let lines = [];
    lines.push(`📦 گزارش بچ ارسال${cfg.batchCode ? ': ' + cfg.batchCode : ''}`);
    lines.push(`📅 تاریخ: ${d}`);
    if (cfg.route) lines.push(`🗺 مسیر: ${cfg.route}`);
    lines.push('');
    lines.push(`👥 تعداد مشتریان: ${customers.length.toLocaleString('fa-IR')}`);
    lines.push(`💵 مجموع خرید مسیر: ${Math.round(totalBuy).toLocaleString('fa-IR')} تومان`);
    lines.push(`🚚 کرایه کل مسیر: ${Math.round(totalFreight).toLocaleString('fa-IR')} تومان`);
    lines.push(`📐 پرشدگی خودرو: ${fillPct.toFixed(1)}٪`);
    lines.push('');
    if (free) {
      lines.push('✅ وضعیت: حمل رایگان مجاز');
      lines.push('شرکت کل کرایه را پرداخت می‌کند.');
    } else {
      lines.push('⚠️ وضعیت: حمل رایگان فعال نیست');
      if (minBuy && shortfall > 0) {
        lines.push(`کسری خرید: ${Math.round(shortfall).toLocaleString('fa-IR')} تومان`);
      }
    }
    lines.push('');
    lines.push('--- تخصیص کرایه ---');
    customers.forEach(c => {
      const buy = parseFloat(c.buy)||0;
      const buyShare = totalBuy > 0 ? buy/totalBuy : 0;
      const fs = totalFreight * buyShare;
      const cc = buy * (cfg.commitPct/100);
      const comp = free ? fs : Math.min(fs, cc);
      const cust = Math.max(0, fs - comp);
      lines.push(`• ${c.name||'بدون نام'}: ${cust > 0 ? Math.round(cust).toLocaleString('fa-IR') + ' تومان' : 'رایگان'}`);
    });
    box.textContent = lines.join('\n');
  }

  function set(id, val) {
    const el = document.getElementById(id);
    if (el) el.textContent = val;
  }

  function copyMsg() {
    const t = document.getElementById('msgBox').textContent;
    navigator.clipboard.writeText(t).then(() => {
      const btn = event.target;
      btn.textContent = '✅ کپی شد';
      setTimeout(() => btn.textContent = 'کپی متن', 2000);
    });
  }

  function loadSample() {
    customers = [];
    document.getElementById('route').value = 'تهران — کرج';
    document.getElementById('batchCode').value = 'B-1042';
    document.getElementById('baseRate').value = '2000000';
    document.getElementById('stopCost').value = '100000';
    document.getElementById('capacity').value = '20';
    document.getElementById('commitPct').value = '2';
    document.getElementById('minFill').value = '70';
    const sample = [
      ['احمدی‌پور', '18000000', '5'],
      ['حسینی', '12000000', '3.5'],
      ['رضایی', '8500000', '2'],
      ['موسوی', '22000000', '7'],
    ];
    sample.forEach(([n,b,m]) => {
      cid++;
      customers.push({id:cid, name:n, buy:b, m2:m});
    });
    renderCustomers();
    recalc();
  }

  function exportCSV() {
    const cfg = getConfig();
    let rows = [['نام مشتری','مبلغ خرید','متراژ']];
    customers.forEach(c => rows.push([c.name, c.buy, c.m2]));
    const csv = rows.map(r => r.join(',')).join('\n');
    const a = document.createElement('a');
    a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent('\uFEFF' + csv);
    a.download = `batch-${cfg.batchCode||'export'}.csv`;
    a.click();
  }

  // Live recalc on config change
  document.querySelectorAll('input,select').forEach(el => {
    el.addEventListener('input', recalc);
  });

  recalc();
</script>
</body>
</html>
